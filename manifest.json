{
  "manifest_version": 3,
  "name": "HTML 转 Figma 助手",
  "version": "1.0.0",
  "description": "HTML 转 Figma 助手：一键抓取网页和本地 HTML，并转换为可编辑设计稿。开发者：Zhou_e。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "logo/icon16.png",
    "48": "logo/icon48.png",
    "128": "logo/icon128.png"
  },
  "action": {
    "default_title": "HTML 转 Figma 助手",
    "default_icon": {
      "16": "logo/icon16.png",
      "48": "logo/icon48.png",
      "128": "logo/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "capture-official.js",
        "runner.js",
        "assets/anan.png",
        "logo/icon16.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
